# TinQa Weather Sync System
    # A production-grade Raspberry Pi system for weather-reactive LED dioramas. This system features a modular architecture designed for high-altitude touring conditions and commercial deployment.

# 📁 Project Structure
    # The project follows Domain-Driven Design and SOLID principles to ensure code maintainability and scalability.

# Plaintext
    # TinQa_Weather_Sync_System/
    # ├── app/                  -Main Application Logic
    # │   ├── api/              -FastAPI Routes & Schemas
    # │   ├── config/           -Configuration & Constants
    # │   ├── hardware/         -Device & LED Management
    # │   ├── services/         -BLE, WiFi, Weather, and Rendering
    # │   ├── utils/            -System & Network Utilities
    # │   └── workers/          -Thread & Background Managers
    # ├── tests/                -Rigorous Test Suite
    # ├── scripts/              -Deployment & Setup Scripts
    # ├── systemd/              -Linux Service Configuration
    # └── requirements.txt      -Project Dependencies

# 🚀 Installation & Setup
    # 1. Prerequisites (macOS/Linux)
        # Ensure you have Python 3.9+ and pip installed. For local development on macOS, install system dependencies via Homebrew:
        # Bash
            brew install dbus glib gobject-introspection

    # 2. Virtual Environment Setup
        # Initialize the virtual environment from the root directory:
        # Bash
            cd TinQa_Weather_Sync_System
            python3 -m venv venv
            source venv/bin/activate  -On Windows: venv\Scripts\activate

# 3. Install Dependencies
    # Install the required packages using the centralized requirements file:

        # Bash
            # Upgrade pip first
                ./venv/bin/pip install --upgrade pip

            # Install project requirements
                ./venv/bin/pip install -r requirements.txt
                # Note for macOS: If BLE libraries fail to install, use the local development command:
                pip install fastapi uvicorn pyserial numpy Pillow requests bleak

                # 🛠 Running the Application
                # To start the system with the modular architecture, run the module from the root directory to ensure absolute imports resolve correctly:

                # Bash
                    ./venv/bin/python3 -m app.main
                    # API URL: http://localhost:21324

                    # Swagger UI Documentation: http://localhost:21324/docs

# 🧪 Testing & Quality Assurance
# The system includes a rigorous test suite using pytest to validate core logic and API integration.

    # 1. Execute Unit & Integration Tests
        # Bash
        # Install testing tools
            ./venv/bin/pip install pytest pytest-cov httpx

        # Run the suite
            ./venv/bin/pytest tests/ -v
    # 2. Generate Coverage Report
        # Generate a comprehensive report to verify code reliability:

        # Bash
            ./venv/bin/pytest --cov=app tests/ --cov-report=html
            # Open htmlcov/index.html in your browser to view the full coverage breakdown.

# 📡 Deployment to Raspberry Pi
    # To deploy the code and automatically restart the Linux service on your Pi:
        # master one liner for PI setup
        # Bash
            ssh pi@192.168.29.170 "sudo systemctl stop tinqa.service 2>/dev/null; sudo systemctl stop bluetooth 2>/dev/null; sudo systemctl disable tinqa.service 2>/dev/null; sudo rm -f /etc/systemd/system/tinqa.service; sudo rm -rf ~/TinQa_Weather_Sync_System; sudo rm -f /var/lib/bluetooth/*/cache/* 2>/dev/null; sudo rm -f /etc/dbus-1/system.d/tinqa_ble.conf; sudo rm -f /etc/sudoers.d/tinqa_nmcli; sudo systemctl daemon-reload; echo '--- PI CLEANED (BLE RESET INCLUDED) ---'" && rsync -avz --exclude '__pycache__' /Users/gaurav/Desktop/TinQa/TinQa_Weather_Sync_System pi@192.168.29.170:~/ && ssh -t pi@192.168.29.170 "set -e; sudo apt update && sudo apt install -y python3-dev python3-venv libdbus-1-dev python3-dbus build-essential pkg-config libglib2.0-dev libgirepository1.0-dev bluez network-manager; sudo usermod -aG bluetooth,lp,netdev pi; echo 'pi ALL=(ALL) NOPASSWD: /usr/bin/nmcli' | sudo tee /etc/sudoers.d/tinqa_nmcli > /dev/null; sudo chmod 440 /etc/sudoers.d/tinqa_nmcli; sudo systemctl enable bluetooth; sudo systemctl restart bluetooth; sleep 5; sudo rfkill unblock bluetooth || true; sudo systemctl restart dbus; sleep 3; sudo nmcli general permissions || true; cd ~/TinQa_Weather_Sync_System; rm -rf venv; python3 -m venv venv; ./venv/bin/pip install --upgrade pip setuptools wheel; ./venv/bin/pip install uvicorn fastapi pyserial bleak dbus-python dbus-next numpy Pillow bless; echo -e '[Unit]\nDescription=TinQa Weather Sync System\nAfter=network.target bluetooth.service NetworkManager.service\nRequires=bluetooth.service\n\n[Service]\nExecStart=/home/pi/TinQa_Weather_Sync_System/venv/bin/python /home/pi/TinQa_Weather_Sync_System/main.py\nWorkingDirectory=/home/pi/TinQa_Weather_Sync_System\nRestart=always\nRestartSec=5\nUser=pi\nEnvironment=PYTHONUNBUFFERED=1\n\n[Install]\nWantedBy=multi-user.target' | sudo tee /etc/systemd/system/tinqa.service > /dev/null; sudo systemctl daemon-reload; sudo systemctl enable tinqa.service; sudo systemctl restart tinqa.service; sleep 10; echo '--- BLUETOOTH STATUS ---'; systemctl status bluetooth --no-pager; echo '--- WIFI PERMISSIONS ---'; groups pi; echo '--- SUDOERS ---'; sudo cat /etc/sudoers.d/tinqa_nmcli; echo '--- TINQA SERVICE LOGS ---'; journalctl -u tinqa.service -n 120 --no-pager"
            # OR
            ssh pi@raspberrypi.local "sudo systemctl stop tinqa.service 2>/dev/null; sudo systemctl stop bluetooth 2>/dev/null; sudo systemctl disable tinqa.service 2>/dev/null; sudo rm -f /etc/systemd/system/tinqa.service; sudo rm -rf ~/TinQa_Weather_Sync_System; sudo rm -f /var/lib/bluetooth/*/cache/* 2>/dev/null; sudo rm -f /etc/dbus-1/system.d/tinqa_ble.conf; sudo rm -f /etc/sudoers.d/tinqa_nmcli; sudo systemctl daemon-reload; echo '--- PI CLEANED (BLE RESET INCLUDED) ---'" && rsync -avz --exclude '__pycache__' /Users/gaurav/Desktop/TinQa/TinQa_Weather_Sync_System pi@raspberrypi.local:~/ && ssh -t pi@raspberrypi.local "set -e; sudo apt update && sudo apt install -y python3-dev python3-venv libdbus-1-dev python3-dbus build-essential pkg-config libglib2.0-dev libgirepository1.0-dev bluez network-manager; sudo usermod -aG bluetooth,lp,netdev pi; echo 'pi ALL=(ALL) NOPASSWD: /usr/bin/nmcli' | sudo tee /etc/sudoers.d/tinqa_nmcli > /dev/null; sudo chmod 440 /etc/sudoers.d/tinqa_nmcli; sudo systemctl enable bluetooth; sudo systemctl restart bluetooth; sleep 5; sudo rfkill unblock bluetooth || true; sudo systemctl restart dbus; sleep 3; sudo nmcli general permissions || true; cd ~/TinQa_Weather_Sync_System; rm -rf venv; python3 -m venv venv; ./venv/bin/pip install --upgrade pip setuptools wheel; ./venv/bin/pip install uvicorn fastapi pyserial bleak dbus-python dbus-next numpy Pillow bless; echo -e '[Unit]\nDescription=TinQa Weather Sync System\nAfter=network.target bluetooth.service NetworkManager.service\nRequires=bluetooth.service\n\n[Service]\nExecStart=/home/pi/TinQa_Weather_Sync_System/venv/bin/python /home/pi/TinQa_Weather_Sync_System/main.py\nWorkingDirectory=/home/pi/TinQa_Weather_Sync_System\nRestart=always\nRestartSec=5\nUser=pi\nEnvironment=PYTHONUNBUFFERED=1\n\n[Install]\nWantedBy=multi-user.target' | sudo tee /etc/systemd/system/tinqa.service > /dev/null; sudo systemctl daemon-reload; sudo systemctl enable tinqa.service; sudo systemctl restart tinqa.service; sleep 10; echo '--- BLUETOOTH STATUS ---'; systemctl status bluetooth --no-pager; echo '--- WIFI PERMISSIONS ---'; groups pi; echo '--- SUDOERS ---'; sudo cat /etc/sudoers.d/tinqa_nmcli; echo '--- TINQA SERVICE LOGS ---'; journalctl -u tinqa.service -n 120 --no-pager"

            ssh pi@192.168.29.170 "sudo systemctl stop tinqa.service 2>/dev/null; sudo systemctl stop bluetooth 2>/dev/null; sudo systemctl disable tinqa.service 2>/dev/null; sudo rm -f /etc/systemd/system/tinqa.service; sudo rm -rf ~/TinQa_Weather_Sync_System; sudo rm -f /var/lib/bluetooth/*/cache/* 2>/dev/null; sudo systemctl daemon-reload; echo '--- PI CLEANED ---'" && \
            rsync -avz --exclude '__pycache__' --exclude 'venv' --exclude 'htmlcov' --exclude '.pytest_cache' /Users/gaurav/Desktop/TinQa/TinQa_Weather_Sync_System/ pi@192.168.29.170:~/TinQa_Weather_Sync_System/ && \
            ssh -t pi@192.168.29.170 "set -e; sudo apt update && sudo apt install -y python3-dev python3-venv libdbus-1-dev python3-dbus build-essential pkg-config libglib2.0-dev libgirepository1.0-dev bluez network-manager; \
            sudo usermod -aG bluetooth,lp,netdev pi; \
            echo 'pi ALL=(ALL) NOPASSWD: /usr/bin/nmcli' | sudo tee /etc/sudoers.d/tinqa_nmcli > /dev/null; \
            sudo chmod 440 /etc/sudoers.d/tinqa_nmcli; \
            sudo systemctl enable bluetooth; sudo systemctl restart bluetooth; sleep 2; \
            cd ~/TinQa_Weather_Sync_System; rm -rf venv; python3 -m venv venv; \
            ./venv/bin/pip install --upgrade pip setuptools wheel; \
            if [ -f requirements.txt ]; then ./venv/bin/pip install -r requirements.txt; else ./venv/bin/pip install uvicorn fastapi pyserial bleak dbus-python dbus-next numpy Pillow bless; fi; \
            echo -e '[Unit]\nDescription=TinQa Weather Sync System\nAfter=network.target bluetooth.service NetworkManager.service\n\n[Service]\nExecStart=/home/pi/TinQa_Weather_Sync_System/venv/bin/python -m app.main\nWorkingDirectory=/home/pi/TinQa_Weather_Sync_System\nRestart=always\nUser=pi\nEnvironment=PYTHONUNBUFFERED=1\nEnvironment=PYTHONPATH=/home/pi/TinQa_Weather_Sync_System\n\n[Install]\nWantedBy=multi-user.target' | sudo tee /etc/systemd/system/tinqa.service > /dev/null; \
            sudo systemctl daemon-reload; sudo systemctl enable tinqa.service; sudo systemctl restart tinqa.service; \
            sleep 5; echo '--- DEPLOYMENT COMPLETE ---'; journalctl -u tinqa.service -n 50 --no-pager"
   
    # Clear Pi’s SSH fingerprint
        # Bash
            ssh-keygen -R raspberrypi.local

    # health report
        # Bash
            ssh -t pi@raspberrypi.local "journalctl -u tinqa.service -n 50 --no-pager"

    # File Update command and Restart Service
        # Go to Project Directory (gaurav@Gauravs-MacBook-Pro TinQa_Weather_Sync_System)
        # Bash
            scp ble_wifi_setup.py pi@raspberrypi.local:~/TinQa_Weather_Sync_System/ \
            && echo "✅ Files uploaded successfully" \
            && ssh -t pi@raspberrypi.local "sudo systemctl restart tinqa.service && echo '✅ Service restarted successfully' || echo '❌ Service restart failed'" \
            || echo "❌ File upload failed"

    # Re-upload ONLY one file
        # Bash 
            scp core/wifi_manager.py core/ble_server.py pi@raspberrypi.local:~/TinQa_Weather_Sync_System/core/ && ssh -t pi@raspberrypi.local "sudo systemctl restart tinqa.service && echo '✅ File updated and service restarted.'"
            
    # PI Shut down
        # Bash
            ssh -t pi@raspberrypi.local "sudo shutdown -h now"

    # Direct Ip pi access
        # Bash
            ssh pi@192.168.29.170

    #Check Avaialble Wifi
        # Bash
            sudo nmcli device wifi rescan
            sleep 5
            nmcli device wifi list
